PORT=3000
JWT_SECRET=altere-esta-chave-em-producao
JWT_EXPIRES_IN=24h
CORS_ORIGIN=*

# Firebase Firestore (obrigatório em desenvolvimento/produção)
# Baixe a chave em: Firebase Console → Configurações → Contas de serviço
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Alternativa: JSON da conta de serviço em uma linha (CI/Docker)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Testes usam memória automaticamente (não precisa configurar Firebase para npm test)
